# Database
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# File Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS="jpg,jpeg,png,webp,gif"